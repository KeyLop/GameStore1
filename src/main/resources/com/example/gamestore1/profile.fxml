<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.gamestore1.ProfileController"
      style="-fx-background-color: #12121e; -fx-padding: 20; -fx-spacing: 15;">

    <Label text="👤 Профиль" style="-fx-text-fill: #e8e8ff; -fx-font-size: 24; -fx-font-weight: bold;"/>

    <VBox style="-fx-background-color: #1a1a30; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #2a2a4a; -fx-border-radius: 12;">
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="👤" style="-fx-font-size: 36;"/>
            <VBox spacing="3">
                <Label fx:id="nameLabel" style="-fx-text-fill: #e8e8ff; -fx-font-size: 18; -fx-font-weight: bold;"/>
                <Label fx:id="emailLabel" style="-fx-text-fill: #8888aa; -fx-font-size: 13;"/>
            </VBox>
        </HBox>
    </VBox>

    <Label text="✏️ Редактировать" style="-fx-text-fill: #d4d4e8; -fx-font-size: 16; -fx-font-weight: bold;"/>

    <TextField fx:id="editNameField" promptText="Новое имя"
               style="-fx-background-color: #1e1e34; -fx-text-fill: #e0e0f0; -fx-prompt-text-fill: #666688; -fx-background-radius: 10; -fx-border-color: #2e2e4a; -fx-border-radius: 10; -fx-padding: 10 16;"/>

    <TextField fx:id="editEmailField" promptText="Новый email"
               style="-fx-background-color: #1e1e34; -fx-text-fill: #e0e0f0; -fx-prompt-text-fill: #666688; -fx-background-radius: 10; -fx-border-color: #2e2e4a; -fx-border-radius: 10; -fx-padding: 10 16;"/>

    <PasswordField fx:id="editPassField" promptText="Новый пароль"
                   style="-fx-background-color: #1e1e34; -fx-text-fill: #e0e0f0; -fx-prompt-text-fill: #666688; -fx-background-radius: 10; -fx-border-color: #2e2e4a; -fx-border-radius: 10; -fx-padding: 10 16;"/>

    <Button text="💾 Сохранить" onAction="#saveProfile"
            style="-fx-background-color: #3b6ea5; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 10 30; -fx-background-radius: 10; -fx-cursor: hand;" maxWidth="Infinity"/>

    <Label fx:id="messageLabel" style="-fx-text-fill: #6fcf97; -fx-font-size: 14;"/>
</VBox>