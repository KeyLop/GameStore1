<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.gamestore1.CartController"
      style="-fx-background-color: #12121e; -fx-padding: 20; -fx-spacing: 15;">

    <Label text="🛒 Корзина" style="-fx-text-fill: #e8e8ff; -fx-font-size: 24; -fx-font-weight: bold;"/>

    <ListView fx:id="cartListView" VBox.vgrow="ALWAYS"
              style="-fx-background-color: #0e0e1a; -fx-control-inner-background: #0e0e1a; -fx-border-color: #1e1e34; -fx-border-radius: 10; -fx-background-radius: 10;"/>

    <HBox spacing="20" alignment="CENTER_RIGHT">
        <Label text="💰 Итого:" style="-fx-text-fill: #aab; -fx-font-size: 16;"/>
        <Label fx:id="totalLabel" text="0.00 ₽"
               style="-fx-text-fill: #6fcf97; -fx-font-size: 22; -fx-font-weight: bold;"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="🗑️ Очистить" onAction="#clearCart"
                style="-fx-background-color: #6a2a2a; -fx-text-fill: #f0d0d0; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button text="✅ Оформить" onAction="#checkout"
                style="-fx-background-color: #2d7d6f; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 8 30; -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>

    <Label fx:id="messageLabel" style="-fx-text-fill: #f28b82; -fx-font-size: 14;"/>
</VBox>