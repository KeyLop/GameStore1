<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gamestore1.MainController"
            style="-fx-background-color: #12121e;">

    <top>
        <VBox spacing="0">
            <!-- Верхняя панель -->
            <HBox style="-fx-background-color: #0a0a14; -fx-padding: 8 20;" spacing="15" alignment="CENTER_LEFT">
                <Label text="🎮" style="-fx-text-fill: #6a8caf; -fx-font-size: 20;"/>
                <Label text="GameStore" style="-fx-text-fill: #e8e8ff; -fx-font-size: 18; -fx-font-weight: bold;"/>
                <Label fx:id="welcomeLabel" style="-fx-text-fill: #666688; -fx-font-size: 13;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Навигация -->
            <HBox style="-fx-background-color: #14142a; -fx-padding: 6 20; -fx-border-color: #1e1e3a; -fx-border-width: 0 0 1 0;" spacing="5">
                <Button text="📚 Каталог" onAction="#showCatalog"
                        style="-fx-background-color: transparent; -fx-text-fill: #aab; -fx-padding: 6 14; -fx-font-size: 13; -fx-cursor: hand; -fx-background-radius: 6;"/>
                <Button text="📖 Библиотека" onAction="#showLibrary"
                        style="-fx-background-color: transparent; -fx-text-fill: #aab; -fx-padding: 6 14; -fx-font-size: 13; -fx-cursor: hand; -fx-background-radius: 6;"/>
                <Button text="🛒 Корзина" onAction="#showCart"
                        style="-fx-background-color: transparent; -fx-text-fill: #aab; -fx-padding: 6 14; -fx-font-size: 13; -fx-cursor: hand; -fx-background-radius: 6;"/>
                <Button text="👤 Профиль" onAction="#showProfile"
                        style="-fx-background-color: transparent; -fx-text-fill: #aab; -fx-padding: 6 14; -fx-font-size: 13; -fx-cursor: hand; -fx-background-radius: 6;"/>
                <Button text="👥 Друзья" onAction="#showFriends"
                        style="-fx-background-color: transparent; -fx-text-fill: #aab; -fx-padding: 6 14; -fx-font-size: 13; -fx-cursor: hand; -fx-background-radius: 6;"/>
                <Button text="⚙️ Админ" onAction="#showAdmin"
                        style="-fx-background-color: transparent; -fx-text-fill: #aab; -fx-padding: 6 14; -fx-font-size: 13; -fx-cursor: hand; -fx-background-radius: 6;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox fx:id="contentArea" style="-fx-padding: 20; -fx-spacing: 15;"/>
    </center>
</BorderPane>