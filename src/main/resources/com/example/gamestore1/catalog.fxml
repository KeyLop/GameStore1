<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.gamestore1.CatalogController"
      style="-fx-background-color: #12121e; -fx-padding: 20; -fx-spacing: 15;">

    <Label text="📚 Каталог игр" style="-fx-text-fill: #e8e8ff; -fx-font-size: 24; -fx-font-weight: bold;"/>

    <HBox spacing="12">
        <TextField fx:id="searchField" promptText="🔍 Поиск игр..." onKeyReleased="#searchGames"
                   style="-fx-background-color: #1e1e34; -fx-text-fill: #e0e0f0; -fx-prompt-text-fill: #666688; -fx-background-radius: 10; -fx-border-color: #2e2e4a; -fx-border-radius: 10; -fx-padding: 10 16;" HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="genreFilter"
                  style="-fx-background-color: #1e1e34; -fx-text-fill: #e0e0f0; -fx-border-color: #2e2e4a; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 6 12;"/>
    </HBox>

    <ListView fx:id="gameListView" VBox.vgrow="ALWAYS"
              style="-fx-background-color: #0e0e1a; -fx-control-inner-background: #0e0e1a; -fx-border-color: #1e1e34; -fx-border-radius: 10; -fx-background-radius: 10;"/>

    <Label fx:id="statusLabel" style="-fx-text-fill: #666688; -fx-font-size: 13;"/>
</VBox>